rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ──────────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isOwner() {
      return isAuth() && getUserRole() == 'owner';
    }

    function isAdmin() {
      return isAuth() && getUserRole() in ['owner', 'admin'];
    }

    function isEditor() {
      return isAuth() && getUserRole() in ['owner', 'admin', 'editor'];
    }

    // ─── Pieces (products) ─────────────────────────────────────────────────────

    match /pieces/{pieceId} {
      allow read: if true;                     // Public: anyone can browse
      allow create, update: if isEditor();     // Editors+ can create/edit
      allow delete: if isAdmin();              // Admin+ can delete
    }

    // ─── Collections (categories) ──────────────────────────────────────────────

    match /collections/{colId} {
      allow read: if true;                     // Public
      allow create, update: if isEditor();     // Editors+
      allow delete: if isAdmin();              // Admin+
    }

    // ─── Reviews ───────────────────────────────────────────────────────────────

    match /reviews/{reviewId} {
      allow read: if true;                     // Public (filtered by approved in queries)
      allow create: if true;                   // Anyone can submit a review
      allow update, delete: if isAdmin();      // Admin+ moderates reviews
    }

    // ─── Subscriptions (newsletter) ────────────────────────────────────────────

    match /subscriptions/{subId} {
      allow read: if isAdmin();                // Admin only
      allow create: if true;                   // Anyone can subscribe
      allow update, delete: if isAdmin();      // Admin manages
    }

    // ─── Inquiries (contact form leads) ────────────────────────────────────────

    match /inquiries/{inqId} {
      allow read: if isEditor();               // Editors+ can see leads
      allow create: if true;                   // Anyone can send inquiry
      allow update: if isEditor();             // Mark as read, etc.
      allow delete: if isAdmin();              // Admin cleans up
    }

    // ─── Users (role management) ───────────────────────────────────────────────

    match /users/{userId} {
      allow read: if isAuth() && (request.auth.uid == userId || isAdmin());
      allow create: if isOwner();              // Only owner creates users
      allow update: if isOwner() ||            // Owner can change any role
                       (isAdmin() && userId != request.auth.uid); // Admin can edit non-self
      allow delete: if isOwner();              // Only owner removes users
    }

    // ─── Config (site settings, status) ────────────────────────────────────────

    match /config/{docId} {
      allow read: if true;                     // Public (health check, site config)
      allow write: if isOwner();               // Only owner changes config
    }

    // ─── Push Tokens ───────────────────────────────────────────────────────────

    match /push_tokens/{tokenId} {
      allow read: if isAdmin();                // Admin sees subscribers
      allow create, update: if true;           // Anyone registers their token
      allow delete: if isAdmin();
    }
  }
}
