rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ─── Piece images ─────────────────────────────────────────────────────────
    // Path: pieces/{pieceId}/{filename}
    match /pieces/{pieceId}/{allPaths=**} {
      allow read: if true;                     // Public: images are shown on site
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024   // Max 10 MB
                   && request.resource.contentType.matches('image/.*');
    }

    // ─── Collection banners ───────────────────────────────────────────────────
    // Path: collections/{colId}/{filename}
    match /collections/{colId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // ─── General site assets ──────────────────────────────────────────────────
    // Path: assets/{filename}
    match /assets/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 15 * 1024 * 1024;
    }

    // Deny everything else by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
